<!--
  IL2CPP managed-code stripping guard.
  UnityVolumeRendering's DICOM importer uses the bundled managed openDICOM.NET library
  (in the UnityVolumeRendering.3rdParty assembly). Some of that parsing is data-driven and
  can be reached in ways the linker cannot trace, so preserve it (and System.Data, which it
  references) to avoid MissingMethod/Type errors when importing DICOM on Android.

  Unity.InputSystem is preserved because MotionSlicer references sensor/pointer device types
  (AttitudeSensor, Touchscreen, Mouse); stripping any of these can make the MotionSlicer type
  fail to load in an IL2CPP build (the component then goes missing at runtime while its
  Input-System-free siblings still load).
-->
<linker>
  <assembly fullname="UnityVolumeRendering.3rdParty" preserve="all" />
  <assembly fullname="UnityVolumeRendering.Runtime" preserve="all" />
  <assembly fullname="System.Data" preserve="all" />
  <assembly fullname="Unity.InputSystem" preserve="all" />
  <!-- Our own scripts: guard every MonoBehaviour against managed stripping so none can go
       "missing script" in the IL2CPP build. -->
  <assembly fullname="Assembly-CSharp" preserve="all" />
</linker>
